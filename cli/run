#!/bin/bash

set -euo pipefail

CLI_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PIPELINES_DIR="$CLI_DIR/pipelines"
REPO_ROOT="$(cd "$CLI_DIR/.." && pwd)"
MANIFEST="$REPO_ROOT/pipelines.yaml"

if [ ! -f "$MANIFEST" ]; then
  echo "run: pipeline manifest not found at $MANIFEST -- deploy is broken" >&2
  exit 1
fi

# shellcheck disable=SC1091
source "$CLI_DIR/manifest.sh"
# shellcheck disable=SC1091
source "$CLI_DIR/resources.sh"

# `run` is its own process, so it has to source each pipeline's env_setup.sh
# itself -- functions from the caller's shell don't carry over.
PIPELINE_NAMES=()
declare -A PIPELINE_ENV_VAR
declare -A PIPELINE_SIF_VAR

while IFS=: read -r p_name p_module p_env_relpath p_env_var p_sif_var p_resources_yaml; do
  [ -z "$p_name" ] && continue
  case "$p_name" in \#*) continue ;; esac

  module_file="$PIPELINES_DIR/$p_module"
  if [ ! -f "$module_file" ]; then
    echo "run: pipeline '$p_name' in $MANIFEST references missing module $module_file" >&2
    exit 1
  fi
  # shellcheck disable=SC1090
  source "$module_file"

  env_file="$REPO_ROOT/$p_env_relpath"
  if [ -f "$env_file" ]; then
    # shellcheck disable=SC1090
    source "$env_file"
  fi

  PIPELINE_NAMES+=("$p_name")
  PIPELINE_ENV_VAR["$p_name"]="$p_env_var"
  PIPELINE_SIF_VAR["$p_name"]="$p_sif_var"
done < <(load_pipeline_manifest "$MANIFEST")

# Every pipeline's env_setup.sh sets apptainer_rclone()/SIF under the same
# names, so whichever one loads last wins -- fine for pipeline-specific
# commands, but `run sync` isn't tied to one pipeline, so it resolves a SIF
# here explicitly (first pipeline in manifest order with its sif_var set).
_sync_apptainer_rclone() {
  local sif="" name sif_var
  for name in "${PIPELINE_NAMES[@]}"; do
    sif_var="${PIPELINE_SIF_VAR[$name]-}"
    [ -z "$sif_var" ] && continue
    if [ -n "${!sif_var-}" ]; then
      sif="${!sif_var}"
      break
    fi
  done
  if [ -z "$sif" ]; then
    echo "run sync: no pipeline SIF is set -- has any pipeline's env_setup.sh run (see setup.sh)?" >&2
    return 1
  fi
  apptainer exec --env "RCLONE_CONFIG=${RCLONE_CONFIG-}" "$sif" rclone "$@"
}

require_pipeline_env() {
  local name="$1" var="${PIPELINE_ENV_VAR[$1]-}"
  if [ -z "$var" ] || [ -z "${!var-}" ]; then
    echo "run $name: environment not set up -- expected \$$var to be set after sourcing ${name}'s env_setup.sh (see setup.sh)" >&2
    exit 1
  fi
}

usage() {
  cat <<EOF
run -- run and monitor pipelines

Usage:
EOF
  local name
  for name in "${PIPELINE_NAMES[@]}"; do
    "${name}_help"
  done
  cat <<'EOF'

Other commands:
  run status
  run logs <pipeline> ...
  run sync <src> <dst> [rclone flags...]
  run queue <pipeline> ...
  run list
  run node [partition]        show live CPU/memory usage and jobs on illorent (or any partition)
  run pipeline-new <name>     scaffold a new pipeline from pipelines/_template into pipelines/<name>

`run sync` is a thin, unopinionated wrapper around `rclone copy` -- no
default excludes, no baked-in direction, just whichever two paths you give
it (either can be a gdrive: remote path or a local scratch path). Anything
after the two paths is passed straight through to rclone, e.g.:
  run sync gdrive:Miniscope/AnalyzedData/mouse/2025-01-01/tp1 \
           $SCRATCH/Miniscope/AnalyzedData/mouse/2025-01-01/tp1
  run sync $SCRATCH/Miniscope/AnalyzedData/mouse/2025-01-01/tp1 \
           gdrive:Miniscope/AnalyzedData/mouse/2025-01-01/tp1 \
           --exclude '*.mmap' --exclude '*.avi'
EOF
}

cmd_status() {
  local names="lab_pipelines_deploy"
  local name
  for name in "${PIPELINE_NAMES[@]}"; do
    names="$names,$("${name}_job_names")"
  done
  squeue -u "$USER" --name="$names"
}

cmd_logs() {
  local pipeline="${1-}"; shift || true
  local name
  for name in "${PIPELINE_NAMES[@]}"; do
    if [ "$pipeline" = "$name" ]; then
      require_pipeline_env "$name"
      "cmd_logs_${name}" "$@"
      return
    fi
  done
  echo "run logs: pipeline must be one of: ${PIPELINE_NAMES[*]}" >&2
  exit 1
}

cmd_sync() {
  # Goes through _sync_apptainer_rclone (not the ambient apptainer_rclone --
  # see its definition above) since plain `rclone` isn't on Sherlock's
  # compute node PATH, and the ambient one is pipeline-order-dependent.
  local src="${1-}" dst="${2-}"
  if [ -z "$src" ] || [ -z "$dst" ]; then
    echo "run sync: usage: run sync <src> <dst> [rclone flags...]" >&2
    exit 1
  fi
  shift 2
  _sync_apptainer_rclone copy "$src" "$dst" --progress "$@"
}

cmd_queue() {
  local pipeline="${1-}"; shift || true
  local name
  for name in "${PIPELINE_NAMES[@]}"; do
    if [ "$pipeline" = "$name" ]; then
      if declare -f "cmd_queue_${name}" >/dev/null; then
        require_pipeline_env "$name"
        "cmd_queue_${name}" "$@"
        return
      fi
      echo "run queue: '$name' doesn't have a top-level queue dry run -- check its own subcommands (e.g. 'run $name queue ...')" >&2
      exit 1
    fi
  done
  echo "run queue: pipeline must be one of: ${PIPELINE_NAMES[*]}" >&2
  exit 1
}

cmd_list() {
  echo "Pipelines and stages currently wired up:"
  echo ""
  local name
  for name in "${PIPELINE_NAMES[@]}"; do
    "${name}_list_entry"
    echo ""
  done
  echo "other commands: status, logs, sync, queue, list, node, pipeline-new -- run 'run --help' for details"
}

cmd_pipeline_new() {
  local name="${1-}"
  case "$name" in
    "")
      echo "run pipeline-new: usage: run pipeline-new <name>" >&2
      exit 1
      ;;
    *[!A-Za-z0-9_-]*)
      echo "run pipeline-new: invalid name '$name' -- use only letters, digits, underscore, hyphen" >&2
      exit 1
      ;;
  esac

  local template_dir="$REPO_ROOT/pipelines/_template"
  local dest_dir="$REPO_ROOT/pipelines/$name"
  local cli_module_dest="$PIPELINES_DIR/$name.sh"

  if [ ! -d "$template_dir" ]; then
    echo "run pipeline-new: template not found at $template_dir -- is the repo deployed correctly?" >&2
    exit 1
  fi
  if [ -e "$dest_dir" ]; then
    echo "run pipeline-new: $dest_dir already exists -- pick a different name or remove it first" >&2
    exit 1
  fi
  if [ -e "$cli_module_dest" ]; then
    echo "run pipeline-new: $cli_module_dest already exists -- pick a different name or remove it first" >&2
    exit 1
  fi

  local name_upper name_title
  name_upper="$(echo "$name" | tr '[:lower:]-' '[:upper:]_')"
  name_title="$(echo "${name:0:1}" | tr '[:lower:]' '[:upper:]')${name:1}"

  # Skip the template's own README -- that's about using the template,
  # not documentation for the new pipeline.
  mkdir -p "$dest_dir"
  local f rel out
  while IFS= read -r -d '' f; do
    rel="${f#"$template_dir"/}"
    out="$dest_dir/$rel"
    mkdir -p "$(dirname "$out")"
    cp "$f" "$out"
  done < <(find "$template_dir" -type f ! -name README.md -print0)

  # This is a real pipeline dir now, not the inert template, so the check
  # can go live: deploy_check.sh.example -> deploy_check.sh.
  if [ -f "$dest_dir/deploy_check.sh.example" ]; then
    mv "$dest_dir/deploy_check.sh.example" "$dest_dir/deploy_check.sh"
  fi

  cp "$PIPELINES_DIR/_template.sh" "$cli_module_dest"

  # Swap TEMPLATE/Template/template/<name> placeholders for the real name,
  # in every case they appear in.
  while IFS= read -r -d '' f; do
    sed -i \
      -e "s/TEMPLATE/${name_upper}/g" \
      -e "s/Template/${name_title}/g" \
      -e "s/template/${name}/g" \
      -e "s/<name>/${name}/g" \
      "$f"
  done < <(find "$dest_dir" "$cli_module_dest" -type f -print0)

  echo "run pipeline-new: created pipelines/$name/ and cli/pipelines/$name.sh"
  echo ""
  echo "Next steps:"
  echo "  1. Fill in pipelines/$name/Dockerfile, common/env_setup.sh, and resources.yaml,"
  echo "     and replace example_stage/ with your real stage script(s)."
  echo "  2. Implement cli/pipelines/$name.sh for real (it currently just mirrors"
  echo "     the template's single example-stage/dashboard commands)."
  echo "  3. Add test commands for '$name' alongside the existing pipelines' tests."
  echo "  4. Add one entry for '$name' to the repo root's pipelines.yaml."
  echo "     Nothing else needs editing -- CI/deploy discover everything from that entry."
}

cmd_node() {
  local partition="${1:-illorent}"

  if ! sinfo -p "$partition" -h &>/dev/null || [ -z "$(sinfo -p "$partition" -h 2>/dev/null)" ]; then
    echo "run node: partition '$partition' not found or unavailable" >&2
    return 1
  fi

  local nodelist cpu_alloc cpu_total mem_alloc_mb mem_total_mb
  nodelist=$(sinfo -p "$partition" -h -o "%N" | head -1)
  local first_node
  first_node=$(sinfo -p "$partition" -h -o "%n" | head -1)
  local sc
  sc=$(scontrol show node "$first_node" 2>/dev/null)
  cpu_alloc=$(echo "$sc" | grep -oP 'CPUAlloc=\K\d+')
  cpu_total=$(echo "$sc" | grep -oP 'CPUTot=\K\d+')
  mem_alloc_mb=$(echo "$sc" | grep -oP 'AllocMem=\K\d+')
  mem_total_mb=$(echo "$sc" | grep -oP 'RealMemory=\K\d+')

  local mem_alloc_gb=$(( mem_alloc_mb / 1024 ))
  local mem_total_gb=$(( mem_total_mb / 1024 ))
  local cpu_pct=$(( cpu_total > 0 ? cpu_alloc * 100 / cpu_total : 0 ))
  local mem_pct=$(( mem_total_gb > 0 ? mem_alloc_gb * 100 / mem_total_gb : 0 ))

  _draw_bar() {
    local used=$1 total=$2 width=24
    local filled=$(( total > 0 ? used * width / total : 0 ))
    local i; for ((i=0; i<width; i++)); do
      ((i < filled)) && printf '█' || printf '░'
    done
  }

  echo ""
  printf "  partition : %s\n"   "$partition"
  printf "  node(s)   : %s\n"   "$nodelist"
  echo   "  ──────────────────────────────────────────────"
  printf "  CPUs      : %s  %d/%d (%d%%)\n" \
    "$(_draw_bar "$cpu_alloc" "$cpu_total")" "$cpu_alloc" "$cpu_total" "$cpu_pct"
  printf "  Memory    : %s  %d/%d GB (%d%%)\n" \
    "$(_draw_bar "$mem_alloc_gb" "$mem_total_gb")" "$mem_alloc_gb" "$mem_total_gb" "$mem_pct"
  echo   "  ──────────────────────────────────────────────"
  echo ""

  local hdr="  %-12s %-12s %-22s %5s %9s %10s\n"
  # squeue -o uses Slurm's own format spec ([.][size]type)
  local fmt="  %12i %12u %22j %5C %9m %10M\n"

  local running
  running=$(squeue -p "$partition" -h -t RUNNING -o "$fmt" 2>/dev/null)
  if [ -n "$running" ]; then
    local n; n=$(echo "$running" | wc -l)
    printf "  RUNNING (%d job%s)\n" "$n" "$([[ $n -eq 1 ]] && echo '' || echo 's')"
    # shellcheck disable=SC2059
    printf "$hdr" "JOBID" "USER" "NAME" "CPUS" "MEM" "RUNTIME"
    printf '%s\n' "$running"
  else
    echo "  RUNNING  — none"
  fi

  echo ""

  local pending
  pending=$(squeue -p "$partition" -h -t PENDING -o "  %12i %12u %22j %5C %9m\n" 2>/dev/null)
  if [ -n "$pending" ]; then
    local n; n=$(echo "$pending" | wc -l)
    printf "  PENDING (%d job%s waiting)\n" "$n" "$([[ $n -eq 1 ]] && echo '' || echo 's')"
    printf "  %-12s %-12s %-22s %5s %9s\n" "JOBID" "USER" "NAME" "CPUS" "MEM"
    printf '%s\n' "$pending"
  else
    echo "  PENDING  — none"
  fi

  echo ""
}

cmd="${1-}"
case "$cmd" in
  status)       shift; cmd_status "$@" ;;
  logs)         shift; cmd_logs "$@" ;;
  sync)         shift; cmd_sync "$@" ;;
  queue)        shift; cmd_queue "$@" ;;
  list)         shift; cmd_list "$@" ;;
  node)         shift; cmd_node "$@" ;;
  pipeline-new) shift; cmd_pipeline_new "$@" ;;
  -h|--help|"") usage ;;
  *)
    for name in "${PIPELINE_NAMES[@]}"; do
      if [ "$cmd" = "$name" ]; then
        require_pipeline_env "$name"
        shift
        "cmd_${name}" "$@"
        exit $?
      fi
    done
    echo "run: unknown command '$cmd'" >&2
    usage
    exit 1
    ;;
esac
