#!/bin/bash
# `run` -- the one command a lab member needs to run pipelines, check on
# them, and find their logs, without ever cd-ing into the deployed tree or
# remembering sbatch argument order/paths.
#
# Manifest-driven: cli/pipelines.yaml lists each pipeline (name, its
# cli/pipelines/<name>.sh module, its env_setup.sh, the env var to sanity-
# check after sourcing it). This file itself stays generic -- it sources
# every pipeline's module and env_setup.sh, then dispatches by name.
# Per-pipeline logic (cmd_<name>, cmd_logs_<name>, optionally
# cmd_queue_<name>, plus <name>_job_names/<name>_list_entry/<name>_help for
# `run status`/`run list`/`run --help`) lives in cli/pipelines/<name>.sh,
# found purely by naming convention -- no registration step beyond the one
# entry in cli/pipelines.yaml. Adding a third pipeline means adding one
# entry there and one new file, not touching this one.
#
# This file (and everything it sources) is deployed through the same
# `current` symlink as everything else (env_setup.sh puts cli/ on $PATH),
# so it updates automatically on every deploy -- no separate install/
# versioning story.

set -euo pipefail

CLI_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PIPELINES_DIR="$CLI_DIR/pipelines"
REPO_ROOT="$(cd "$CLI_DIR/.." && pwd)"
MANIFEST="$CLI_DIR/pipelines.yaml"

if [ ! -f "$MANIFEST" ]; then
  echo "run: pipeline manifest not found at $MANIFEST -- deploy is broken" >&2
  exit 1
fi

# shellcheck disable=SC1091
source "$CLI_DIR/manifest.sh"

# --- load every pipeline from the manifest ----------------------------------
# `run` bootstraps its OWN environment here (sources each pipeline's
# env_setup.sh directly, unconditionally) rather than depending on the
# caller's shell having already sourced anything. Two reasons: (1) shell
# FUNCTIONS defined by env_setup.sh (apptainer_python, apptainer_rclone,
# ...) do NOT cross process boundaries the way exported env vars do -- `run`
# is found via $PATH and executed as its own child process, so even a
# caller who dutifully sourced env_setup.sh in their interactive shell
# leaves this process with none of those functions defined, unless we
# source it again ourselves, in here. (2) this also means `run` works from
# a completely fresh shell with nothing pre-sourced, which is a nice bonus.
# Safe/idempotent to source twice if the caller's shell also did it.
PIPELINE_NAMES=()
declare -A PIPELINE_ENV_VAR

while IFS=: read -r p_name p_module p_env_relpath p_env_var p_sif_var; do
  [ -z "$p_name" ] && continue
  case "$p_name" in \#*) continue ;; esac

  module_file="$PIPELINES_DIR/$p_module"
  if [ ! -f "$module_file" ]; then
    echo "run: pipeline '$p_name' in $MANIFEST references missing module $module_file" >&2
    exit 1
  fi
  # shellcheck disable=SC1090
  source "$module_file"

  env_file="$REPO_ROOT/$p_env_relpath"
  if [ -f "$env_file" ]; then
    # shellcheck disable=SC1090
    source "$env_file"
  fi

  PIPELINE_NAMES+=("$p_name")
  PIPELINE_ENV_VAR["$p_name"]="$p_env_var"
done < <(load_pipeline_manifest "$MANIFEST")

# --- generic env sanity gate, called by dispatch below ----------------------
# Checked once per pipeline invocation, using the required_env_var column
# from the manifest -- catches a missing/broken env_setup.sh (e.g. this
# pipeline's env file didn't exist at $env_file above) with one clear error
# instead of a confusing "command not found" three layers down.
require_pipeline_env() {
  local name="$1" var="${PIPELINE_ENV_VAR[$1]-}"
  if [ -z "$var" ] || [ -z "${!var-}" ]; then
    echo "run $name: environment not set up -- expected \$$var to be set after sourcing ${name}'s env_setup.sh (see cli/setup.sh)" >&2
    exit 1
  fi
}

# --- usage / help -------------------------------------------------------

usage() {
  cat <<EOF
run -- run and monitor lab pipelines, no cd required

Usage:
EOF
  local name
  for name in "${PIPELINE_NAMES[@]}"; do
    "${name}_help"
  done
  cat <<'EOF'

Other commands:
  run status
  run logs <pipeline> ...
  run sync <src> <dst> [rclone flags...]
  run queue <pipeline> ...
  run list
  run node [partition]        show live CPU/memory usage and jobs on illorent (or any partition)

`run sync` is a thin, unopinionated wrapper around `rclone copy` -- no
default excludes, no baked-in direction, just whichever two paths you give
it (either can be a gdrive: remote path or a local scratch path). Anything
after the two paths is passed straight through to rclone, e.g.:
  run sync gdrive:Miniscope/AnalyzedData/VK_.../2025-01-01/tp1 \
           $SCRATCH/Miniscope/AnalyzedData/VK_.../2025-01-01/tp1
  run sync $SCRATCH/Miniscope/AnalyzedData/VK_.../2025-01-01/tp1 \
           gdrive:Miniscope/AnalyzedData/VK_.../2025-01-01/tp1 \
           --exclude '*.mmap' --exclude '*.avi'
EOF
}

# --- generic subcommands -------------------------------------------------

cmd_status() {
  # Scoped to every pipeline's known job names (collected from each
  # module's <name>_job_names) plus a small fixed base list, rather than a
  # bare `squeue -u`, so this doesn't also show unrelated interactive/
  # other-project jobs.
  local names="lab_pipelines_deploy"
  local name
  for name in "${PIPELINE_NAMES[@]}"; do
    names="$names,$("${name}_job_names")"
  done
  squeue -u "$USER" --name="$names"
}

cmd_logs() {
  local pipeline="${1-}"; shift || true
  local name
  for name in "${PIPELINE_NAMES[@]}"; do
    if [ "$pipeline" = "$name" ]; then
      require_pipeline_env "$name"
      "cmd_logs_${name}" "$@"
      return
    fi
  done
  echo "run logs: pipeline must be one of: ${PIPELINE_NAMES[*]}" >&2
  exit 1
}

cmd_sync() {
  # Deliberately raw: no default --exclude, no assumed direction. sync.sh
  # (used internally after every MC/CNMF-E run) still bakes in the
  # mmap/avi excludes that make sense for that specific, automatic case --
  # this command is the general-purpose escape hatch for everything else,
  # so the safety net is opt-in per call (pass --exclude yourself) rather
  # than baked in. Goes through apptainer_rclone since plain `rclone` isn't
  # on Sherlock's compute node PATH.
  local src="${1-}" dst="${2-}"
  if [ -z "$src" ] || [ -z "$dst" ]; then
    echo "run sync: usage: run sync <src> <dst> [rclone flags...]" >&2
    exit 1
  fi
  shift 2
  apptainer_rclone copy "$src" "$dst" --progress "$@"
}

cmd_queue() {
  # `run queue <pipeline> ...` dispatches to cmd_queue_<pipeline> if that
  # pipeline's module defines one -- not every pipeline has a top-level
  # queue dry-run in this shape (moseq's lives at `run moseq queue <name>`
  # instead, since it needs a project name, not --mouse-style filters).
  local pipeline="${1-}"; shift || true
  local name
  for name in "${PIPELINE_NAMES[@]}"; do
    if [ "$pipeline" = "$name" ]; then
      if declare -f "cmd_queue_${name}" >/dev/null; then
        require_pipeline_env "$name"
        "cmd_queue_${name}" "$@"
        return
      fi
      echo "run queue: '$name' doesn't have a top-level queue dry run -- check its own subcommands (e.g. 'run $name queue ...')" >&2
      exit 1
    fi
  done
  echo "run queue: pipeline must be one of: ${PIPELINE_NAMES[*]}" >&2
  exit 1
}

cmd_list() {
  echo "Pipelines and stages currently wired up:"
  echo ""
  local name
  for name in "${PIPELINE_NAMES[@]}"; do
    "${name}_list_entry"
    echo ""
  done
  echo "other commands: status, logs, sync, queue, list, node -- run 'run --help' for details"
}

cmd_node() {
  local partition="${1:-illorent}"

  if ! sinfo -p "$partition" -h &>/dev/null || [ -z "$(sinfo -p "$partition" -h 2>/dev/null)" ]; then
    echo "run node: partition '$partition' not found or unavailable" >&2
    return 1
  fi

  # Use scontrol for accurate AllocMem/RealMemory (sinfo's %e can return N/A)
  local nodelist cpu_alloc cpu_total mem_alloc_mb mem_total_mb
  nodelist=$(sinfo -p "$partition" -h -o "%N" | head -1)
  local first_node
  first_node=$(sinfo -p "$partition" -h -o "%n" | head -1)
  local sc
  sc=$(scontrol show node "$first_node" 2>/dev/null)
  cpu_alloc=$(echo "$sc" | grep -oP 'CPUAlloc=\K\d+')
  cpu_total=$(echo "$sc" | grep -oP 'CPUTot=\K\d+')
  mem_alloc_mb=$(echo "$sc" | grep -oP 'AllocMem=\K\d+')
  mem_total_mb=$(echo "$sc" | grep -oP 'RealMemory=\K\d+')

  local mem_alloc_gb=$(( mem_alloc_mb / 1024 ))
  local mem_total_gb=$(( mem_total_mb / 1024 ))
  local cpu_pct=$(( cpu_total > 0 ? cpu_alloc * 100 / cpu_total : 0 ))
  local mem_pct=$(( mem_total_gb > 0 ? mem_alloc_gb * 100 / mem_total_gb : 0 ))

  _draw_bar() {
    local used=$1 total=$2 width=24
    local filled=$(( total > 0 ? used * width / total : 0 ))
    local i; for ((i=0; i<width; i++)); do
      ((i < filled)) && printf '█' || printf '░'
    done
  }

  echo ""
  printf "  partition : %s\n"   "$partition"
  printf "  node(s)   : %s\n"   "$nodelist"
  echo   "  ──────────────────────────────────────────────"
  printf "  CPUs      : %s  %d/%d (%d%%)\n" \
    "$(_draw_bar "$cpu_alloc" "$cpu_total")" "$cpu_alloc" "$cpu_total" "$cpu_pct"
  printf "  Memory    : %s  %d/%d GB (%d%%)\n" \
    "$(_draw_bar "$mem_alloc_gb" "$mem_total_gb")" "$mem_alloc_gb" "$mem_total_gb" "$mem_pct"
  echo   "  ──────────────────────────────────────────────"
  echo ""

  # All jobs on this partition (all users -- point is to see contention)
  local hdr="  %-12s %-12s %-22s %5s %9s %10s\n"
  local fmt="  %-12i %-12u %-22j %5C %9m %10M\n"

  local running
  running=$(squeue -p "$partition" -h -t RUNNING -o "$fmt" 2>/dev/null)
  if [ -n "$running" ]; then
    local n; n=$(echo "$running" | wc -l)
    printf "  RUNNING (%d job%s)\n" "$n" "$([[ $n -eq 1 ]] && echo '' || echo 's')"
    # shellcheck disable=SC2059
    printf "$hdr" "JOBID" "USER" "NAME" "CPUS" "MEM" "RUNTIME"
    printf '%s\n' "$running"
  else
    echo "  RUNNING  — none"
  fi

  echo ""

  local pending
  pending=$(squeue -p "$partition" -h -t PENDING -o "  %-12i %-12u %-22j %5C %9m\n" 2>/dev/null)
  if [ -n "$pending" ]; then
    local n; n=$(echo "$pending" | wc -l)
    printf "  PENDING (%d job%s waiting)\n" "$n" "$([[ $n -eq 1 ]] && echo '' || echo 's')"
    printf "  %-12s %-12s %-22s %5s %9s\n" "JOBID" "USER" "NAME" "CPUS" "MEM"
    printf '%s\n' "$pending"
  else
    echo "  PENDING  — none"
  fi

  echo ""
}

# --- dispatch ----------------------------------------------------------

cmd="${1-}"
case "$cmd" in
  status)       shift; cmd_status "$@" ;;
  logs)         shift; cmd_logs "$@" ;;
  sync)         shift; cmd_sync "$@" ;;
  queue)        shift; cmd_queue "$@" ;;
  list)         shift; cmd_list "$@" ;;
  node)         shift; cmd_node "$@" ;;
  -h|--help|"") usage ;;
  *)
    for name in "${PIPELINE_NAMES[@]}"; do
      if [ "$cmd" = "$name" ]; then
        require_pipeline_env "$name"
        shift
        "cmd_${name}" "$@"
        exit $?
      fi
    done
    echo "run: unknown command '$cmd'" >&2
    usage
    exit 1
    ;;
esac
