#!/bin/bash
# Sanity check run by deploy/poll_and_deploy.sh before promoting a new
# commit to `current`. Same idea as moseq/deploy_check.sh and
# miniscope/deploy_check.sh: fast syntax checks, no Apptainer.
#
# IMPORTANT: named deploy_check.sh.example here so it stays inert.
# poll_and_deploy.sh runs any file literally named deploy_check.sh under
# pipelines/*/, ungated by pipelines.yaml -- if this were named that here,
# it'd fail on every real deploy. Only rename it once it's inside your
# real pipelines/<name>/ directory.

set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")"

bash -n common/env_setup.sh
bash -n example_stage/example_stage.sbatch

python3 -c "import yaml; yaml.safe_load(open('resources.yaml'))"

# Add one `bash -n <script>` per real stage script, plus a quick check for
# any pure-Python logic -- see pipelines/moseq/deploy_check.sh for the
# pattern.

echo "<name>: syntax OK"
